# deploy/netlify/netlify.toml.example
[build]
  command = "npm run build"
  publish = "dist"

[dev]
  command = "npm run dev"
  targetPort = 5173
  port = 8888

# Optional if you use Netlify Functions in this repo.
[functions]
  node_bundler = "esbuild"

# SPA fallback for React Router.
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
