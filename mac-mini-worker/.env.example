# Mac Mini Worker Environment Configuration
# Copy this to .env and fill in your credentials

# Supabase Configuration
SUPABASE_URL=https://ftxbphwlqskimdnqcfxh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Worker Configuration
WORKER_ID=mac-mini-worker-1
WORKER_POOL_SIZE=2
JOB_POLL_INTERVAL_MS=5000
JOB_MAX_RUNTIME_SECONDS=300
HEARTBEAT_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Optional: AI/OpenClaw Integration
# (To be configured later for neural_scout, scenario_runner, etc.)
AI_API_KEY=
AI_PROVIDER=heuristic
