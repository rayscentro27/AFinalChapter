[Unit]
Description=Nexus Monitoring Runner (per-tenant, one-shot)
After=network-online.target nexus-gateway.service
Wants=nexus-gateway.service

[Service]
Type=oneshot
User=opc
WorkingDirectory=/home/opc/afinal_gateway
EnvironmentFile=/home/opc/afinal_gateway/.env
ExecStart=/usr/bin/bash /home/opc/afinal_gateway/scripts/monitoring_cron.sh
Nice=10

[Install]
WantedBy=multi-user.target
