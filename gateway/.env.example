PORT=3000
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=true
ALLOWED_ORIGINS=https://app.goclearonline.cc
ALLOW_NETLIFY_PREVIEWS=true

INTERNAL_API_KEY=change_me_long_random
ORACLE_CRON_TOKEN=change_me_cron_token
ORACLE_TENANT_IDS=00000000-0000-0000-0000-000000000000,11111111-1111-1111-1111-111111111111
ORACLE_API_BASE_URL=http://127.0.0.1:3000
AI_FUNDING_COMPLIANCE_RUN_LIMIT=50
AI_FUNDING_COMPLIANCE_STALE_MINUTES=30

ALERTS_WEBHOOK_URL=
ALERTS_NOTIFY_ON_RESOLVE=true
ALERT_NOTIFICATION_COOLDOWN_MINUTES=30
ALERT_OUTBOX_FAILED_THRESHOLD=10
ALERT_OUTBOX_OLDEST_DUE_MINUTES_THRESHOLD=15
ALERT_WEBHOOK_FAILED_24H_THRESHOLD=10
ALERT_DELIVERY_FAILED_THRESHOLD=10
ALERT_CHANNELS_DOWN_THRESHOLD=1

SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+15551234567

META_APP_SECRET=YOUR_META_APP_SECRET
META_VERIFY_TOKEN=your_meta_verify_token
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

WHATSAPP_TOKEN=EAAG...
WHATSAPP_GRAPH_VERSION=v19.0
WHATSAPP_WEBHOOK_SECRET=

META_PAGE_ACCESS_TOKEN=EAAG...
META_GRAPH_VERSION=v19.0

MATRIX_WEBHOOK_TOKEN=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
ENABLE_NIM_DEV=false

AI_PROVIDER=heuristic
AI_API_KEY=
AI_MASK_PII=true
AI_MAX_INPUT_CHARS=12000
AI_MAX_PROVIDER_RETRIES=2
OPENROUTER_ALLOWED_TASKS=research_summary,transcript_summary,structured_extraction,opportunity_detection,opportunity_brief,rewrite,style_normalization,video_script_draft
OPENROUTER_DENIED_TASKS=credit_report_analysis,credit_dispute_generation,billing_decision,authorization_decision,tenant_policy_decision,trading_execution,broker_execution,live_trading

# Phase 1 runtime controls (queue/worker scaffolding)
SYSTEM_MODE=development
QUEUE_ENABLED=false
AI_JOBS_ENABLED=true
RESEARCH_JOBS_ENABLED=true
NOTIFICATIONS_ENABLED=true
JOB_MAX_RUNTIME_SECONDS=300
WORKER_MAX_CONCURRENCY=4
TENANT_JOB_LIMIT_ACTIVE=20
WORKER_HEARTBEAT_SECONDS=60
ENV_VALIDATE_STRICT=false
