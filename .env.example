# Web (Netlify/Vite)
VITE_API_BASE_URL=https://api.goclearonline.cc
VITE_BACKEND_MODE=supabase
VITE_SUPABASE_URL=https://<SUPABASE_PROJECT>.supabase.co
VITE_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
VITE_TURNSTILE_ENABLED=true
VITE_TURNSTILE_SITE_KEY=<TURNSTILE_SITE_KEY>
# Local Vite development can opt out via a non-committed .env.development.local override:
# VITE_TURNSTILE_ENABLED=false

# Gateway API (Fastify on Oracle VM)
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=true
TRUST_PROXY_CIDRS=127.0.0.1/32,::1/128
TRUST_PROXY_ALLOW_ALL=false
ALLOWED_ORIGINS=https://app.goclearonline.cc
ALLOW_NETLIFY_PREVIEWS=false

INTERNAL_API_KEY=<CHANGE_ME_LONG_RANDOM>
ORACLE_CRON_TOKEN=<CHANGE_ME_CRON_TOKEN>
ORACLE_TENANT_IDS=<TENANT_UUID_1>,<TENANT_UUID_2>
ORACLE_API_BASE_URL=http://127.0.0.1:3000
AI_FUNDING_COMPLIANCE_RUN_LIMIT=50
AI_FUNDING_COMPLIANCE_STALE_MINUTES=30

ALERTS_NOTIFY_ON_RESOLVE=true
ALERT_NOTIFICATION_COOLDOWN_MINUTES=30
ALERT_OUTBOX_FAILED_THRESHOLD=10
ALERT_OUTBOX_OLDEST_DUE_MINUTES_THRESHOLD=15
ALERT_WEBHOOK_FAILED_24H_THRESHOLD=10
ALERT_DELIVERY_FAILED_THRESHOLD=10
ALERT_CHANNELS_DOWN_THRESHOLD=1

SUPABASE_URL=https://<SUPABASE_PROJECT>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_JWT_SECRET=<SUPABASE_JWT_SECRET>

TRADINGVIEW_WEBHOOK_SECRET=<TRADINGVIEW_WEBHOOK_SECRET>
OANDA_API_KEY=<OANDA_API_KEY>
OANDA_ACCOUNT_ID=<OANDA_ACCOUNT_ID>
OANDA_URL=https://api-fxpractice.oanda.com
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<TELEGRAM_CHAT_ID>


META_APP_SECRET=<META_APP_SECRET>
META_VERIFY_TOKEN=<META_VERIFY_TOKEN>


META_PAGE_ACCESS_TOKEN=<META_PAGE_ACCESS_TOKEN>
META_GRAPH_VERSION=v19.0

MATRIX_WEBHOOK_TOKEN=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=<LONG_RANDOM_ENCRYPTION_SECRET>
# Optional key rotation controls for tenant integration credentials
INTEGRATION_CREDENTIALS_ENCRYPTION_ACTIVE_KID=2026-rotation-a
INTEGRATION_CREDENTIALS_ENCRYPTION_KEYRING={"2026-rotation-a":"<LONG_RANDOM_ENCRYPTION_SECRET>","2025-legacy":"<OLD_SECRET_FOR_READS>"}
INTEGRATION_CREDENTIALS_ENCRYPTION_PREVIOUS_KEY=<OLD_SECRET_FOR_READS>
NVIDIA_NIM_API_KEY=
ENABLE_NIM_DEV=false

AI_PROVIDER=heuristic
AI_API_KEY=
AI_OPENAI_MODEL=gpt-4.1-mini
AI_GEMINI_MODEL=gemini-1.5-flash
AI_MASK_PII=true
SAFE_MODE=false

# Optional SMTP + app URLs (used by enterprise/email flows)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_BASE_URL=https://app.goclearonline.cc
PUBLIC_APP_URL=https://app.goclearonline.cc

# Auth hardening parity (local Supabase CLI)
SUPABASE_AUTH_CAPTCHA_SECRET=

# AI Gateway guardrails (server-side only)
AI_REQUEST_TIMEOUT_MS=20000
AI_REQUEST_RETRIES=2
AI_MAX_CONTEXT_CHARS=12000
AI_TOKEN_BUDGET_LOW=4000
AI_TOKEN_BUDGET_MEDIUM=8000
AI_TOKEN_BUDGET_HIGH=12000
AI_TOKEN_BUDGET_CRITICAL=16000
AI_ALLOW_MODEL_OVERRIDE=false

# Phase 1 runtime controls (queue/worker scaffolding)
SYSTEM_MODE=development
QUEUE_ENABLED=false
AI_JOBS_ENABLED=true
RESEARCH_JOBS_ENABLED=true
NOTIFICATIONS_ENABLED=true
CONTROL_PLANE_WRITE_ENABLED=false
JOB_MAX_RUNTIME_SECONDS=300
WORKER_MAX_CONCURRENCY=4
TENANT_JOB_LIMIT_ACTIVE=20
WORKER_HEARTBEAT_SECONDS=60
ENV_VALIDATE_STRICT=true
