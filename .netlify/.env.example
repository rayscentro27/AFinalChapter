# Used by `netlify dev` for local Functions.
# IMPORTANT: never put the service role key in frontend Vite envs.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

ADMIN_IMPORT_TOKEN=YOUR_LONG_RANDOM_TOKEN
INTEL_INGEST_TOKEN=YOUR_LONG_RANDOM_INTEL_TOKEN
CRON_SHARED_TOKEN=YOUR_LONG_RANDOM_CRON_TOKEN
MAILERLITE_API_KEY=YOUR_MAILERLITE_API_KEY
# Optional fallback if you don't pass groupId from the client.
MAILERLITE_GROUP_ID=YOUR_MAILERLITE_GROUP_ID


OPENAI_API_KEY=YOUR_OPENAI_KEY
# Optional: override model used by the function.
OPENAI_MODEL=gpt-4o-mini

# Gemini key for /.netlify/functions/gemini_generate
GEMINI_API_KEY=YOUR_GEMINI_KEY
# Legacy fallback supported but discouraged
API_KEY=

# Oracle Gateway outbound proxy (preferred)
ORACLE_API_BASE_URL=https://api.yourdomain.com
ORACLE_API_KEY=YOUR_ORACLE_INTERNAL_API_KEY

# Backward-compatible names
ORACLE_BASE_URL=https://api.yourdomain.com
ORACLE_INTERNAL_API_KEY=YOUR_ORACLE_INTERNAL_API_KEY

# Backward-compatible aliases
GATEWAY_BASE_URL=https://api.yourdomain.com
GATEWAY_INTERNAL_API_KEY=YOUR_GATEWAY_INTERNAL_API_KEY

# AI Gateway guardrails (server-side only)
AI_REQUEST_TIMEOUT_MS=20000
AI_REQUEST_RETRIES=2
AI_MAX_CONTEXT_CHARS=12000
AI_TOKEN_BUDGET_LOW=4000
AI_TOKEN_BUDGET_MEDIUM=8000
AI_TOKEN_BUDGET_HIGH=12000
AI_TOKEN_BUDGET_CRITICAL=16000
AI_ALLOW_MODEL_OVERRIDE=false
